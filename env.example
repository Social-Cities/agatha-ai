# GitHub personal access token with repo / issues / pull request permissions
GITHUB_TOKEN=ghp_your_token_here

# Repo owner and repo name
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=your-repo-name

# Absolute path to the local clone on your MacBook
REPO_PATH=/Users/yourname/code/your-repo

# Optional settings
BASE_BRANCH=main
POLL_MS=30000

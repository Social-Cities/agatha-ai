# GitHub personal access token with repo / issues / pull request permissions.
# Used as the default token for any repo in repos.json that does not set its own "token".
GITHUB_TOKEN=ghp_your_token_here

# Optional: path to the multi-repo config file. Defaults to ./repos.json
# REPOS_CONFIG_PATH=/absolute/path/to/repos.json

# Optional settings
POLL_MS=30000
MAX_CONCURRENT=3

# ===== GitHub Authentication =====
# Personal Access Token with repo, issues, and pull request permissions
GITHUB_TOKEN=your-github-token

# ===== Repository Info =====
GITHUB_OWNER=your-org-or-user
GITHUB_REPO=your-repo

# ===== Local Repo Path =====
# Absolute path to your local clone on your MacBook
REPO_PATH=full-path-to-code-repo-to-operate-on

# ===== Worker Settings =====
# Base branch the worker should branch off from
BASE_BRANCH=main

# Poll interval in milliseconds (how often to check for new issues)
POLL_MS=30000

# ===== Concurrency =====
# Maximum number of issues/PRs to work on simultaneously (each gets its own git worktree)
MAX_CONCURRENT=3

# ===== Temporal (only needed for temporal mode) =====
# Address of the Temporal server
TEMPORAL_ADDRESS=localhost:7233

# Temporal namespace
TEMPORAL_NAMESPACE=default

# Task queue name
TEMPORAL_TASK_QUEUE=agatha-github

# ===== Optional (Future Use / Debugging) =====
# LOG_LEVEL=debug

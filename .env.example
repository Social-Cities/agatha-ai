GITHUB_OWNER=your-org-or-user
GITHUB_REPO=your-repo
GITHUB_TOKEN=ghp_xxx
POLL_INTERVAL_SECONDS=60
WORKER_NAME=agatha-mac-worker
BASE_BRANCH=main
ISSUE_LABEL=ai-task
CLAIM_LABEL=ai-worker-processing
DONE_LABEL=ai-worker-complete
FAILED_LABEL=ai-worker-failed
LOCAL_REPO_PATH=/absolute/path/to/your/local/repo
BRANCH_PREFIX=codex/issue
COMMIT_MESSAGE_TEMPLATE=feat: resolve issue #{issue_number}
PR_BASE_BRANCH=main
PR_REVIEWERS=
AI_COMMAND_TEMPLATE=node /absolute/path/to/runner.js --issue "{issue_number}" --title "{issue_title}" --body-file "{issue_body_file}" --repo "{repo_path}" --branch "{branch_name}"
PUSH_BRANCH=true
CREATE_PR=true
